generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  EDITOR
  FIRMA_EDITOR
}

enum CampaignStatus {
  PENDING
  PUBLISHED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   
  role          Role      @default(USER)
  
  brandId       String?   // Firma/Banka editörü ise hangi markaya ait olduğu
  brand         Brand?    @relation(fields: [brandId], references: [id])
  
  isApproved    Boolean   @default(true) 
  
  accounts      Account[]
  sessions      Session[]
  comments      Comment[]
  favorites     Favorite[]
  campaigns     Campaign[] // Campaigns submitted by this user

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Firma/Banka/Marka (e.g., Garanti, BP, Media Markt)
model Brand {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  logoUrl     String?
  isActive    Boolean    @default(true)
  
  // Hiyerarşi: Bir firmanın ana sektörü (e.g., Garanti -> Banka, BP -> Akaryakıt)
  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id])
  
  creditCards CreditCard[]
  campaigns   Campaign[] @relation("CampaignBrands")
  editors     User[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// Kredi Kartı (e.g., Bonus, Wings, Axess)
model CreditCard {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  imageUrl    String?
  isActive    Boolean    @default(true)
  
  brandId     String
  brand       Brand      @relation(fields: [brandId], references: [id])
  
  campaigns   Campaign[] @relation("CampaignCards")
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// Sektör: (Market, Elektronik, Akaryakıt, Banka...)
model Category {
  id        String     @id @default(cuid())
  name      String     
  slug      String     @unique
  icon      String?    
  isActive  Boolean    @default(true)
  
  brands    Brand[]    // Sektöre bağlı markalar
  campaigns Campaign[] @relation("CampaignCategories")
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// Avantaj: (Puan, Artı Taksit, İndirim...)
model Avantaj {
  id        String     @id @default(cuid())
  name      String     
  slug      String     @unique 
  icon      String?    
  isActive  Boolean    @default(true)
  
  campaigns Campaign[] @relation("CampaignAvantajlar")
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Campaign {
  id          String   @id @default(cuid())
  title       String
  description String
  summary     String?  // Özet
  keywords    String?  // Virgülle ayrılmış anahtar kelimeler
  imageUrl    String?
  endDate     DateTime
  
  status      CampaignStatus @default(PENDING) 
  
  // Many-to-Many Relations
  brands      Brand[]      @relation("CampaignBrands")
  categories  Category[]   @relation("CampaignCategories")
  creditCards CreditCard[] @relation("CampaignCards")
  avantajlar  Avantaj[]    @relation("CampaignAvantajlar")

  authorId    String? 
  author      User?   @relation(fields: [authorId], references: [id])

  comments    Comment[]
  favoritedBy Favorite[]

  // SEO & Migration fields
  slug        String   @unique
  oldPhpUrl   String?  @unique 

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Comment {
  id          String   @id @default(cuid())
  text        String
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Favorite {
  id          String   @id @default(cuid())
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([userId, campaignId]) 
}
